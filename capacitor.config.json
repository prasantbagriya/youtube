{
  "appId": "com.vidstream.app",
  "appName": "VidStream",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0f0f0f"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "StatusBar": {
      "overlaysWebView": false,
      "backgroundColor": "#ffffff",
      "style": "DARK"
    }
  }
}
